{
  "app": "AI NotebookLM Runtime Lab",
  "kind": "command_package",
  "version": "0.1",
  "command_id": "cmd_upload_folder_example",
  "command_type": "upload_folder",
  "submitter": "doc_manager",
  "role": "document_manager",
  "target_project_id": "REPLACE_WITH_PROJECT_ID",
  "source": {
    "type": "folder",
    "path": "data/source_pool/simple_upload/incoming",
    "recursive": false,
    "file_types": [".pdf", ".txt", ".md", ".csv", ".docx", ".xlsx", ".pptx"],
    "order": "name"
  },
  "options": {
    "duplicate_policy": "rename",
    "copy_evidence": true,
    "evidence_root": "data/source_pool/simple_upload/evidence"
  },
  "execution": {
    "mode": "manual",
    "requires_confirm": true
  }
}
